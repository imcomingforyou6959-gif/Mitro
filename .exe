-- ============ DETECTION SECTION ============
coroutine.wrap(function()
    local modList = {
        163721789, 15427717, 201454243, 822999, 63794379, 17260230, 28357488,
        93101606, 8195210, 89473551, 16917269, 85989579, 1553950697, 476537893,
        155627580, 31163456, 7200829, 25717070, 16138978, 60660789, 1161411094,
        9125623, 11319153, 34758833, 194109750, 35616559, 1257271138, 28885841,
        23558830, 4255947062, 29242182, 2395613299, 3314981799, 3390225662,
        2459178, 2846299656, 2967502742, 7001683347, 7312775547, 328566086,
        170526279, 99356639, 352087139, 6074834798, 2212830051, 3944434729,
        5136267958, 84570351, 542488819, 1830168970, 3950637598, 1962396833,
    }
    local groupIDs = {10604500, 17215700}
    local function detectModerators()
        while Flags.ModDetectionEnabled do
            task.wait(1)
            for _, player in ipairs(Players:GetPlayers()) do
                for _, modId in ipairs(modList) do
                    if player.UserId == modId then
                        local msg = 'MODERATOR DETECTED: ' .. player.DisplayName
                        if Flags.AntiModMethod == 'Notify' then CreateNotification(msg, 3)
                        else LocalPlayer:Kick(msg) end
                        break
                    end
                end
                if Flags.GroupCheckEnabled then
                    for _, gid in ipairs(groupIDs) do
                        local ok, isIn = pcall(function() return player:IsInGroup(gid) end)
                        if ok and isIn then
                            local role = 'Unknown'; pcall(function() role = player:GetRoleInGroup(gid) end)
                            local gmsg = '[' .. role .. '] JOINED: ' .. player.DisplayName
                            if Flags.AntiModMethod == 'Notify' then CreateNotification(gmsg, 3)
                            else LocalPlayer:Kick(gmsg) end
                        end
                    end
                end
            end
        end
    end
    local AntiModSection = MiscPage:Section({ Name = 'Detection', Side = 2 })
    AntiModSection:Toggle({ Name = 'Mod Detection', Flag = 'ModDetectionEnabled', Default = true, Callback = function(v) CreateNotification(v and 'Anti-Mod Enabled' or 'Anti-Mod Disabled', 3); if v then task.spawn(detectModerators) end end })
    AntiModSection:Dropdown({ Name = 'Anti-Mod Method', Flag = 'AntiModMethod', Default = 'Notify', Multi = false, Items = { 'Notify', 'Kick' }, Callback = function(v) CreateNotification('Anti-Mod Method set to: ' .. v, 3) end })
    AntiModSection:Toggle({ Name = 'Group Role Checking', Flag = 'GroupCheckEnabled', Default = true, Callback = function(v) CreateNotification(v and 'Group Membership Check Enabled' or 'Disabled', 3); if v then task.spawn(detectModerators) end end })
end)()

