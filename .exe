    Knight = { idle1='http://www.roblox.com/asset/?id=657595757', idle2='http://www.roblox.com/asset/?id=657568135', walk='http://www.roblox.com/asset/?id=657552124', run='http://www.roblox.com/asset/?id=657564596', jump='http://www.roblox.com/asset/?id=657560148', climb='http://www.roblox.com/asset/?id=657556206', fall='http://www.roblox.com/asset/?id=657552124' },
}
local function applyCustomAnimations(character)
    if not character then return end
    local Animate = character:FindFirstChild('Animate')
    if not Animate then return end
    local Cloned = Animate:Clone()
    Cloned.idle.Animation1.AnimationId = AnimationSets[Flags.Idle1Animation].idle1
    Cloned.idle.Animation2.AnimationId = AnimationSets[Flags.Idle2Animation].idle2
    Cloned.walk.WalkAnim.AnimationId = AnimationSets[Flags.WalkAnimation].walk
    Cloned.run.RunAnim.AnimationId = AnimationSets[Flags.RunAnimation].run
    Cloned.jump.JumpAnim.AnimationId = AnimationSets[Flags.JumpAnimation].jump
    Cloned.climb.ClimbAnim.AnimationId = AnimationSets[Flags.ClimbAnimation].climb
    Cloned.fall.FallAnim.AnimationId = AnimationSets[Flags.FallAnimation].fall
    Animate:Destroy()
    Cloned.Parent = character
end
LocalPlayer.CharacterAdded:Connect(function(c) if Flags.KeepOnDeath then task.wait(1); applyCustomAnimations(c) end end)
local animNames = { 'Default','Ninja','Zombie','Knight' }
AnimationSection:Dropdown({ Name = 'Idle1', Flag = 'Idle1Animation', Default = 'Default', Items = animNames, Callback = function() applyCustomAnimations(LocalPlayer.Character) end })
AnimationSection:Dropdown({ Name = 'Idle2', Flag = 'Idle2Animation', Default = 'Default', Items = animNames, Callback = function() applyCustomAnimations(LocalPlayer.Character) end })
AnimationSection:Dropdown({ Name = 'Walk', Flag = 'WalkAnimation', Default = 'Default', Items = animNames, Callback = function() applyCustomAnimations(LocalPlayer.Character) end })
AnimationSection:Dropdown({ Name = 'Run', Flag = 'RunAnimation', Default = 'Default', Items = animNames, Callback = function() applyCustomAnimations(LocalPlayer.Character) end })
AnimationSection:Dropdown({ Name = 'Jump', Flag = 'JumpAnimation', Default = 'Default', Items = animNames, Callback = function() applyCustomAnimations(LocalPlayer.Character) end })
AnimationSection:Dropdown({ Name = 'Climb', Flag = 'ClimbAnimation', Default = 'Default', Items = animNames, Callback = function() applyCustomAnimations(LocalPlayer.Character) end })
AnimationSection:Dropdown({ Name = 'Fall', Flag = 'FallAnimation', Default = 'Default', Items = animNames, Callback = function() applyCustomAnimations(LocalPlayer.Character) end })
AnimationSection:Toggle({ Name = 'Keep On Death', Flag = 'KeepOnDeath', Default = false })

-- ============ INIT ============
CreateNotification('Mitro.exe is in', 3)
CreateNotification('Expect Changes script has tons of bugs', 3)
