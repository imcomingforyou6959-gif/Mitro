
local VenyxLibrary = loadstring(game:HttpGet("https://raw.githubusercontent.com/Documantation12/Universal-Vehicle-Script/main/Library.lua"))()
local Venyx = VenyxLibrary.new("Chayce's Scripts, Universal Vehicle Cheat V1", 5013109572)

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer


local Theme = {
	Background = Color3.fromRGB(81, 14, 14), 
	Glow = Color3.fromRGB(255, 0, 0), 
	Accent = Color3.fromRGB(42, 42, 42), 
	LightContrast = Color3.fromRGB(125, 24, 20), 
	DarkContrast = Color3.fromRGB(97, 0, 0),  
	TextColor = Color3.fromRGB(255, 255, 255)
}
for index, value in pairs(Theme) do
	pcall(Venyx.setTheme, Venyx, index, value)
end


local function GetVehicleFromDescendant(Descendant)
	return
		Descendant:FindFirstAncestor(LocalPlayer.Name .. "\'s Car") or
		(Descendant:FindFirstAncestor("Body") and Descendant:FindFirstAncestor("Body").Parent) or
		(Descendant:FindFirstAncestor("Misc") and Descendant:FindFirstAncestor("Misc").Parent) or
		Descendant:FindFirstAncestorWhichIsA("Model")
end


local vehiclePage = Venyx:addPage("Vehicle", 8356815386)
local usageSection = vehiclePage:addSection("Controls")
local velocityEnabled = true
usageSection:addToggle("Keybinds", velocityEnabled, function(v) velocityEnabled = v end)


local flightSection = vehiclePage:addSection("Vehicle Fly")
local flightEnabled = false
local flightSpeed = 1
flightSection:addToggle("Enabled", false, function(v) flightEnabled = v end)
flightSection:addSlider("Speed", 100, 0, 800, function(v) flightSpeed = v / 100 end)


local defaultCharacterParent = nil
local function restoreCharacterParent()
	local character = LocalPlayer.Character
	if character and character.Parent ~= defaultCharacterParent then
		character.Parent = defaultCharacterParent or workspace
	end
end


RunService.Stepped:Connect(function()
	local character = LocalPlayer.Character
	if flightEnabled then
		if character then
			local humanoid = character:FindFirstChildWhichIsA("Humanoid")
			if humanoid then
				local seatPart = humanoid.SeatPart
				if seatPart and seatPart:IsA("VehicleSeat") then
					local vehicle = GetVehicleFromDescendant(seatPart)
					if vehicle and vehicle:IsA("Model") then
						-- Store original parent if not already stored
						if not defaultCharacterParent then
							defaultCharacterParent = character.Parent
						end
						-- Parent character to vehicle to prevent falling out
						character.Parent = vehicle

						-- Ensure PrimaryPart is set
						if not vehicle.PrimaryPart then
							if seatPart.Parent == vehicle then
								vehicle.PrimaryPart = seatPart
							else
								vehicle.PrimaryPart = vehicle:FindFirstChildWhichIsA("BasePart")
							end
						end

						-- Calculate movement
						local cameraLook = workspace.CurrentCamera.CFrame.LookVector
						local move = CFrame.new(0, 0, 0)
						if not UserInputService:GetFocusedTextBox() then
							local forward = (UserInputService:IsKeyDown(Enum.KeyCode.W) and -flightSpeed) or (UserInputService:IsKeyDown(Enum.KeyCode.S) and flightSpeed) or 0
							local right = (UserInputService:IsKeyDown(Enum.KeyCode.D) and flightSpeed) or (UserInputService:IsKeyDown(Enum.KeyCode.A) and -flightSpeed) or 0
							local up = (UserInputService:IsKeyDown(Enum.KeyCode.E) and flightSpeed/2) or (UserInputService:IsKeyDown(Enum.KeyCode.Q) and -flightSpeed/2) or 0
							move = CFrame.new(right, up, forward)
						end

						local primaryCF = vehicle:GetPrimaryPartCFrame()
						vehicle:SetPrimaryPartCFrame(CFrame.new(primaryCF.Position, primaryCF.Position + cameraLook) * move)

						-- Stop physics
						seatPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
						seatPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
					end
				else
					-- Not in a seat, restore parent if needed
					restoreCharacterParent()
				end
			end
		end
	else
		restoreCharacterParent()
	end
end)


local speedSection = vehiclePage:addSection("Top Speed")
local velocityMult = 0.025
speedSection:addSlider("Multiplier (Thousandths)", 25, 0, 50, function(v) velocityMult = v / 500 end)
local velocityEnabledKeyCode = Enum.KeyCode.W
speedSection:addKeybind("Velocity Enabled", velocityEnabledKeyCode, function()
	if not velocityEnabled then return end
	while UserInputService:IsKeyDown(velocityEnabledKeyCode) do
		task.wait()
		local character = LocalPlayer.Character
		if character then
			local humanoid = character:FindFirstChildWhichIsA("Humanoid")
			if humanoid then
				local seatPart = humanoid.SeatPart
				if seatPart and seatPart:IsA("VehicleSeat") then
					-- Apply multiplier in local direction? For simplicity we keep global.
					seatPart.AssemblyLinearVelocity *= Vector3.new(1 + velocityMult, 1, 1 + velocityMult)
				end
			end
		end
		if not velocityEnabled then break end
	end
end, function(v) velocityEnabledKeyCode = v.KeyCode end)


local decelerateSelection = vehiclePage:addSection("Braking")
local brakeForce = 0.15
decelerateSelection:addSlider("Brake Force (Thousandths)", 150, 0, 300, function(v) brakeForce = v / 1000 end)
local qbEnabledKeyCode = Enum.KeyCode.S
decelerateSelection:addKeybind("Quick Brake", qbEnabledKeyCode, function()
	if not velocityEnabled then return end
	while UserInputService:IsKeyDown(qbEnabledKeyCode) do
		task.wait()
		local character = LocalPlayer.Character
		if character then
			local humanoid = character:FindFirstChildWhichIsA("Humanoid")
			if humanoid then
				local seatPart = humanoid.SeatPart
				if seatPart and seatPart:IsA("VehicleSeat") then
					seatPart.AssemblyLinearVelocity *= Vector3.new(1 - brakeForce, 1, 1 - brakeForce)
				end
			end
		end
		if not velocityEnabled then break end
	end
end, function(v) qbEnabledKeyCode = v.KeyCode end)

decelerateSelection:addKeybind("Stop Vehicle", Enum.KeyCode.P, function()
	if not velocityEnabled then return end
	local character = LocalPlayer.Character
	if character then
		local humanoid = character:FindFirstChildWhichIsA("Humanoid")
		if humanoid then
			local seatPart = humanoid.SeatPart
			if seatPart and seatPart:IsA("VehicleSeat") then
				seatPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
				seatPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
			end
		end
	end
end)


local springSection = vehiclePage:addSection("Springs")
springSection:addToggle("Visible", false, function(v)
	local character = LocalPlayer.Character
	if character then
		local humanoid = character:FindFirstChildWhichIsA("Humanoid")
		if humanoid then
			local seatPart = humanoid.SeatPart
			if seatPart and seatPart:IsA("VehicleSeat") then
				local vehicle = GetVehicleFromDescendant(seatPart)
				if vehicle then
					for _, spring in pairs(vehicle:GetDescendants()) do
						if spring:IsA("SpringConstraint") then
							spring.Visible = v
						end
					end
				end
			end
		end
	end
end)


local extraPage = Venyx:addPage("Extra", 8356815386)
local gravitySection = extraPage:addSection("Gravity")
local gravityEnabled = false
local gravityValue = 196.2  -- default Roblox gravity
gravitySection:addToggle("Enabled", false, function(v) 
	gravityEnabled = v
	if not v then
		workspace.Gravity = 196.2  -- reset to default
	end
end)
gravitySection:addSlider("Gravity", gravityValue, 0, 500, function(v)
	gravityValue = v
	if gravityEnabled then
		workspace.Gravity = gravityValue
	end
end)


gravitySection:addButton("Apply Now", function()
	if gravityEnabled then
		workspace.Gravity = gravityValue
	end
end)
