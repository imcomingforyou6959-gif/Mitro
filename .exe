-- ============ UTILITY FUNCTIONS ============
local function getPing()
    return Stats.Network.ServerStatsItem['Data Ping']:GetValue() / 1000
end

local function getPredictedPosition(part)
    if not part or not part.Parent then return part and part.Position end
    local velocity = part.Velocity
    local speed = velocity.Magnitude
    if speed <= 200 or speed > 1200 then return part.Position end
    local ping = getPing()
    return part.Position + velocity * (ping + Flags.PredictValue)
end

function predictPosition(targetRoot, predictionMultiplier)
    if not targetRoot then return nil end
    local velocity = targetRoot.Velocity
    local speed = velocity.Magnitude
    if speed <= 200 or speed > 1200 then return targetRoot.Position end
    local ping = getPing()
    return targetRoot.Position + velocity * (ping + predictionMultiplier)
end

-- ============ NOTIFICATIONS ============
local NotificationGui = Instance.new('ScreenGui')
NotificationGui.Name = 'NotificationGui'
NotificationGui.ResetOnSpawn = false
NotificationGui.IgnoreGuiInset = true
NotificationGui.Parent = CoreGui

local function CreateNotification(message, duration)
    duration = duration or 3
    local frame = Instance.new('Frame')
    frame.Size = UDim2.new(0, 300, 0, 50)
    frame.Position = UDim2.new(1, 20, 0, 20)
    frame.BackgroundColor3 = Colors.Background
    frame.BorderSizePixel = 0
    frame.Parent = NotificationGui

    local corner = Instance.new('UICorner')
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = frame

    local inner = Instance.new('Frame')
    inner.Size = UDim2.new(1, -4, 1, -4)
    inner.Position = UDim2.new(0, 2, 0, 2)
    inner.BackgroundColor3 = Colors.White
    inner.BorderSizePixel = 0
    inner.Parent = frame

    local innerCorner = Instance.new('UICorner')
    innerCorner.CornerRadius = UDim.new(0, 6)
    innerCorner.Parent = inner

    local text = Instance.new('TextLabel')
    text.Size = UDim2.new(1, -10, 1, 0)
    text.Position = UDim2.new(0, 5, 0, 0)
    text.BackgroundTransparency = 1
    text.Text = message
    text.TextColor3 = Colors.Primary
    text.TextSize = 14
    text.Font = Enum.Font.Gotham
    text.TextXAlignment = Enum.TextXAlignment.Left
    text.Parent = inner

    local bar = Instance.new('Frame')
    bar.Size = UDim2.new(1, 0, 0, 3)
    bar.Position = UDim2.new(0, 0, 1, -3)
    bar.BackgroundColor3 = Colors.Secondary
    bar.BorderSizePixel = 0
    bar.Parent = inner

    local barCorner = Instance.new('UICorner')
    barCorner.CornerRadius = UDim.new(0, 2)
    barCorner.Parent = bar

    -- Animate in
    local tweenIn = TweenService:Create(frame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { Position = UDim2.new(1, -320, 0, 20) })
    tweenIn:Play()
    tweenIn.Completed:Wait()

    -- Animate bar
    local tweenBar = TweenService:Create(bar, TweenInfo.new(duration, Enum.EasingStyle.Linear), { Size = UDim2.new(0, 0, 0, 3) })
    tweenBar:Play()

    task.wait(duration)

    -- Animate out
    local tweenOut = TweenService:Create(frame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), { Position = UDim2.new(1, 20, 0, 20) })
    tweenOut:Play()
    tweenOut.Completed:Wait()
    frame:Destroy()
end

-- ============ ANTI‑LOCK SYSTEM ============
-- ALS
local function startAntiLock()
    if antiLockActive then return end
    antiLockActive = true

    -- SRM 
    local heartbeatConn = RunService.Heartbeat:Connect(function()
        if not Flags.AntiLockEnabled then
            heartbeatConn:Disconnect()
            antiLockActive = false
            return
        end
        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild('HumanoidRootPart')
        if hrp then
            -- Very small random offset (barely noticeable, but breaks lock consistency)
            hrp.CFrame = hrp.CFrame * CFrame.new(math.random(-5,5)/100, 0, math.random(-5,5)/100)
        end
    end)
    table.insert(antiLockConnections, heartbeatConn)

    -- Randomize velocity slightly
    local velConn = RunService.Heartbeat:Connect(function()
        if not Flags.AntiLockEnabled then
            velConn:Disconnect()
            return
        end
        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild('HumanoidRootPart')
        if hrp then
            -- Add tiny random velocity (makes prediction harder)
            local v = hrp.Velocity
            hrp.Velocity = v + Vector3.new(math.random(-50,50)/10, 0, math.random(-50,50)/10)
        end
    end)
    table.insert(antiLockConnections, velConn)

    CreateNotification('Anti‑Lock activated – other aimbots will miss', 3)
end

local function stopAntiLock()
    for _, conn in ipairs(antiLockConnections) do
        pcall(function() conn:Disconnect() end)
    end
    antiLockConnections = {}
    antiLockActive = false
end

-- ============ RETURN BY DEATH ============
-- Stores death position
local function onCharacterDied()
    if Flags.ReturnByDeathEnabled then
        local character = LocalPlayer.Character
        if character and character.PrimaryPart then
            deathPosition = character.PrimaryPart.CFrame + Vector3.new(0, 0.5, 0)
        end
    end
end

local function onCharacterAdded(newCharacter)
    -- Connect Died event for this new character
    local humanoid = newCharacter:WaitForChild('Humanoid', 10)
    if humanoid then
        humanoid.Died:Connect(onCharacterDied)
    end

    -- Teleport to stored death position if enabled
    if Flags.ReturnByDeathEnabled and deathPosition then
        local rootPart = newCharacter:WaitForChild('HumanoidRootPart', 5)
        if rootPart then
            rootPart.CFrame = deathPosition
            deathPosition = nil
            CreateNotification('Returned to death location', 3)
        end
    end
end

-- Connect events
LocalPlayer.CharacterAdded:Connect(onCharacterAdded)
if LocalPlayer.Character then
    onCharacterAdded(LocalPlayer.Character)
end

-- ============ WELD FUNCTIONS ============
local function createWeld(part0, part1)
    local weld = Instance.new('Weld')
    weld.Part0 = part0
    weld.Part1 = part1
    weld.C0 = CFrame.new()
    weld.C1 = CFrame.new()
    weld.Parent = part0
    return weld
end

local function stopWeldStomp()
    if weldStompConn then weldStompConn:Disconnect(); weldStompConn = nil end
    if weldStompObj then weldStompObj:Destroy(); weldStompObj = nil end
end

local function stopWeldKill()
    if weldKillConn then weldKillConn:Disconnect(); weldKillConn = nil end
    if weldKillObj then weldKillObj:Destroy(); weldKillObj = nil end
end

local function startWeldStomp(target)
    if not target or not target.Character then return end
    stopWeldStomp() -- stop only stomp, not kill
    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild('HumanoidRootPart')
    local targetRoot = target.Character:FindFirstChild('HumanoidRootPart')
    if not myRoot or not targetRoot then return end

    weldStompObj = createWeld(myRoot, targetRoot)
    weldStompObj.C1 = CFrame.new(0, 3, 0) -- offset above

    weldStompConn = RunService.Heartbeat:Connect(function()
        if not Flags.WeldStompEnabled or not target or not target.Character then
            stopWeldStomp()
            return
        end
        local mainEvent = ReplicatedStorage:FindFirstChild('MainEvent')
        if mainEvent then
            mainEvent:FireServer('Stomp')
        end
    end)
    CreateNotification('Weld Stomp activated', 2)
end

local function startWeldKill(target)
    if not target or not target.Character then return end
    stopWeldKill() -- stop only kill, not stomp
    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild('HumanoidRootPart')
    local targetRoot = target.Character:FindFirstChild('HumanoidRootPart')
    if not myRoot or not targetRoot then return end

    weldKillObj = createWeld(myRoot, targetRoot)
    weldAngle = 0

    weldKillConn = RunService.Heartbeat:Connect(function()
        if not Flags.WeldKillEnabled or not target or not target.Character then
            stopWeldKill()
            return
        end
        weldAngle = weldAngle + math.rad(Flags.WeldKillSpeed)
        local offset = Vector3.new(math.cos(weldAngle) * Flags.WeldKillRadius, 0, math.sin(weldAngle) * Flags.WeldKillRadius)
        weldKillObj.C1 = CFrame.new(offset)
    end)
    CreateNotification('Weld Kill circling', 2)
end

-- ============ ANTI‑LAG ============
-- ALSR
RunService.Heartbeat:Connect(function()
    if Flags.AntiLagEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild('HumanoidRootPart') then
        local hrp = LocalPlayer.Character.HumanoidRootPart
        -- Add tiny random offset (similar to anti-lock but less aggressive)
        hrp.CFrame = hrp.CFrame * CFrame.new(math.random(-3,3)/100, 0, math.random(-3,3)/100)
    end
end)

